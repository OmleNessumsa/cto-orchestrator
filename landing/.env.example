# Coinbase Commerce API Key
COINBASE_COMMERCE_API_KEY=your_api_key_here

# Google Analytics 4 Measurement ID
# Get this from: Google Analytics → Admin → Data Streams → Web stream → Measurement ID
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Rick IDE download URLs (shown on the success page after payment).
# Hosted on the "rick-ide-downloads" Vercel Blob store. Platforms without
# a configured URL are hidden on the success page — set LINUX/WIN once
# those artifacts are built (requires the GitHub Actions release workflow;
# node-pty cannot be cross-compiled from macOS).
RICK_IDE_DOWNLOAD_URL_MAC=
RICK_IDE_DOWNLOAD_URL_LINUX=
RICK_IDE_DOWNLOAD_URL_WIN=
