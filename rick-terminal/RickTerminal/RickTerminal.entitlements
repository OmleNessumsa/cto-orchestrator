<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- SANDBOX DISABLED -->
	<!-- Terminal emulators cannot run in a sandbox - they need to spawn processes -->
	<!-- This is why Terminal.app, iTerm2, Warp, etc. are not sandboxed -->
	<key>com.apple.security.app-sandbox</key>
	<false/>

	<!-- Allow inheriting environment for child processes -->
	<key>com.apple.security.inherit</key>
	<true/>
</dict>
</plist>
